{
  "[typescript]": {
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.formatOnSave": true
  },

  "editor.quickSuggestions": {
    "strings": "on"
  },

  "files.associations": {
    "*.css": "tailwindcss"
  },

  "tailwindCSS.experimental.configFile": "app/globals.css"
}
